# ============================================================================
# Database Configuration (Multi-Database Support)
# ============================================================================

# Method 1: Using individual parameters
# DATABASE_TYPE options: mysql, postgresql, informix, mariadb, oracle, sqlserver
DATABASE_TYPE=mysql

# Common parameters
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=testdb

# Connection Pool Configuration
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Method 2: Using complete DSN (overrides Method 1 if set)
# Uncomment and use one of these based on your database:
#
# MySQL:
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/testdb
#
# PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/testdb
#
# Informix:
# DATABASE_URL=informix+pyodbc://informix:password@localhost:9088/testdb
#
# MariaDB:
# DATABASE_URL=mariadb+pymysql://root:password@localhost:3306/testdb
#
# Oracle (requires cx_oracle):
# DATABASE_URL=oracle+cx_oracle://user:password@localhost:1521/testdb
#
# SQL Server (requires pymssql):
# DATABASE_URL=mssql+pymssql://user:password@localhost:1433/testdb

# ============================================================================
# LLM Configuration (Multi-Provider Support)
# ============================================================================

# Provider options: openai, deepseek, anthropic, ollama
LLM_PROVIDER=openai

# Model format: "provider:model-name" or just "model-name"
# Examples:
#   openai:gpt-4
#   deepseek:deepseek-chat
#   anthropic:claude-opus-4
#   ollama:llama2
LLM_MODEL=openai:gpt-4

# API Keys (provider-specific)
OPENAI_API_KEY=your_openai_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# Deepseek specific configuration (defaults to official API)
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Model parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_TOP_P=1.0
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3

# ============================================================================
# Agent Configuration
# ============================================================================

AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT=300
AGENT_VERBOSE=true
AGENT_DEBUG=false

# ============================================================================
# Database-Specific Examples
# ============================================================================

# MySQL Example:
# DATABASE_TYPE=mysql
# DB_HOST=mysql.example.com
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=mysql_password
# DB_NAME=mysql_db

# PostgreSQL Example:
# DATABASE_TYPE=postgresql
# DB_HOST=postgres.example.com
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres_password
# DB_NAME=postgres_db

# Informix Example:
# DATABASE_TYPE=informix
# DB_HOST=informix.example.com
# DB_PORT=9088
# DB_USER=informix
# DB_PASSWORD=informix_password
# DB_NAME=informix_db

# ============================================================================
# LLM Provider Examples
# ============================================================================

# OpenAI (default):
# LLM_PROVIDER=openai
# LLM_MODEL=openai:gpt-4
# OPENAI_API_KEY=sk-xxx...

# Deepseek:
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek:deepseek-chat
# DEEPSEEK_API_KEY=sk-xxx...

# Anthropic Claude:
# LLM_PROVIDER=anthropic
# LLM_MODEL=anthropic:claude-opus-4
# ANTHROPIC_API_KEY=sk-ant-xxx...

# Ollama (local LLM):
# LLM_PROVIDER=ollama
# LLM_MODEL=ollama:llama2
# (no API key needed for local Ollama)
